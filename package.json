{
  "name": "finansal-takip-sistemi",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:pack": "next build && electron-builder --dir",
    "android:sync": "next build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "build": {
    "appId": "com.finansaltakip.app",
    "productName": "Finansal Takip Sistemi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "electronLanguages": [
      "en-US",
      "tr"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance",
      "identity": null
    },
    "dmg": {
      "title": "Finansal Takip Sistemi"
    }
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@types/jspdf": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^2.30.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.5",
    "xlsx": "^0.18.5"
  }
}
